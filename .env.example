# .env.example – copy to .env and fill in real values before running docker compose
# NEVER commit .env to source control.

# ─── SQL Server ───────────────────────────────────────────────────────────────
# Must be a strong password (SQL Server policy)
SQL_PASSWORD=Change_Me_Strong_P@ssw0rd!

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64-character hex string = 32-byte AES-256 key
ENCRYPTION_KEY=<generate with: openssl rand -hex 32>
# 32-character hex string = 16-byte AES IV
ENCRYPTION_IV=<generate with: openssl rand -hex 16>

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── Application ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
